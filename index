<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OpenClaw — Полный гайд по установке</title>
<meta name="description" content="Пошаговый гайд по установке AI-бота OpenClaw на сервере Aeza. Telegram-бот с ИИ за 15 минут.">
<meta name="theme-color" content="#04040c">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Unbounded:wght@400;500;600;700;800;900&family=Manrope:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg-deep: #04040c;
  --bg-base: #08081a;
  --bg-card: #0e0e24;
  --bg-card-hover: #12122e;
  --bg-code: #0a0a1e;
  --accent: #ff6b4a;
  --accent-glow: rgba(255, 107, 74, 0.15);
  --accent-soft: #ff8a65;
  --accent-gradient: linear-gradient(135deg, #ff6b4a, #ff4444, #ff8a50);
  --text-primary: #e8e8f0;
  --text-secondary: #9898b0;
  --text-muted: #5a5a78;
  --border: #1a1a36;
  --border-glow: rgba(255, 107, 74, 0.25);
  --success: #4ade80;
  --warning: #fbbf24;
  --danger: #f87171;
  --radius: 16px;
  --radius-sm: 10px;
  --radius-xs: 6px;
  --font-sans: 'Manrope', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  --font-heading: 'Unbounded', -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  --font-mono: 'JetBrains Mono', "SF Mono", "Cascadia Code", "Fira Code", Menlo, Consolas, monospace;
}
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; scroll-padding-top: 80px; }
body {
  font-family: var(--font-sans);
  background: var(--bg-deep);
  color: var(--text-primary);
  line-height: 1.75;
  font-size: 16px;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ===== PROGRESS BAR ===== */
.progress-bar {
  position: fixed;
  top: 0;
  left: 0;
  height: 3px;
  background: var(--accent-gradient);
  z-index: 1000;
  transition: width 0.1s linear;
  box-shadow: 0 0 12px rgba(255, 107, 74, 0.5);
}

/* ===== HERO ===== */
.hero {
  position: relative;
  min-height: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 80px 24px 60px;
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 80% 60% at 50% 40%, rgba(255, 68, 68, 0.08) 0%, transparent 70%),
    radial-gradient(ellipse 60% 50% at 20% 80%, rgba(255, 107, 74, 0.05) 0%, transparent 60%),
    radial-gradient(ellipse 50% 40% at 80% 20%, rgba(255, 138, 80, 0.04) 0%, transparent 50%);
  animation: heroShift 20s ease-in-out infinite alternate;
  pointer-events: none;
}
@keyframes heroShift {
  0% { transform: scale(1) translate(0, 0); }
  50% { transform: scale(1.05) translate(-2%, 1%); }
  100% { transform: scale(1) translate(1%, -1%); }
}
.hero-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,107,74,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,107,74,0.03) 1px, transparent 1px);
  background-size: 60px 60px;
  mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 20%, transparent 70%);
  -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 20%, transparent 70%);
  pointer-events: none;
}
.hero-ascii {
  font-family: var(--font-mono);
  font-size: 11px;
  line-height: 1.15;
  color: var(--accent);
  opacity: 0.25;
  white-space: pre;
  margin-bottom: 32px;
  position: relative;
  z-index: 1;
  animation: asciiPulse 4s ease-in-out infinite;
  user-select: none;
}
@keyframes asciiPulse {
  0%, 100% { opacity: 0.2; filter: blur(0px); }
  50% { opacity: 0.35; filter: blur(0.3px); }
}
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 8px 20px;
  border-radius: 100px;
  background: rgba(255, 107, 74, 0.08);
  border: 1px solid rgba(255, 107, 74, 0.2);
  color: var(--accent);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  margin-bottom: 28px;
  position: relative;
  z-index: 1;
}
.hero h1 {
  font-family: var(--font-heading);
  font-size: clamp(36px, 6vw, 64px);
  font-weight: 800;
  line-height: 1.1;
  background: var(--accent-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 20px;
  position: relative;
  z-index: 1;
}
.hero-subtitle {
  font-size: clamp(16px, 2.5vw, 20px);
  color: var(--text-secondary);
  max-width: 620px;
  margin: 0 auto 40px;
  position: relative;
  z-index: 1;
  font-weight: 400;
  text-align: center;
}
.hero-cta {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 16px 36px;
  border-radius: 100px;
  background: var(--accent-gradient);
  color: white;
  font-weight: 700;
  font-size: 16px;
  text-decoration: none;
  position: relative;
  z-index: 1;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  box-shadow: 0 4px 24px rgba(255, 107, 74, 0.25);
}
.hero-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 40px rgba(255, 107, 74, 0.4);
}
.hero-scroll {
  position: absolute;
  bottom: 32px;
  left: 50%;
  transform: translateX(-50%);
  animation: scrollBounce 2s ease-in-out infinite;
  z-index: 1;
}
.hero-scroll svg { width: 24px; height: 24px; color: var(--text-muted); }
@keyframes scrollBounce {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(8px); }
}

/* ===== REQUIREMENTS BOX ===== */
.requirements {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 32px;
  margin-bottom: 56px;
}
.requirements h3 {
  font-family: var(--font-heading);
  font-size: 18px;
  font-weight: 700;
  color: var(--accent);
  margin-bottom: 20px;
}
.requirements ul { list-style: none; }
.requirements li {
  padding: 10px 0;
  padding-left: 32px;
  position: relative;
  color: var(--text-secondary);
  font-size: 15px;
}
.requirements li::before {
  content: "✓";
  position: absolute;
  left: 0;
  color: var(--success);
  font-weight: 700;
  font-size: 16px;
}
.requirements a {
  color: var(--accent);
  text-decoration: none;
  border-bottom: 1px solid transparent;
  transition: border-color 0.2s;
}
.requirements a:hover { border-bottom-color: var(--accent); }

/* ===== MAIN CONTENT ===== */
.container {
  max-width: 860px;
  margin: 0 auto;
  padding: 0 24px 100px;
}

/* ===== PART HEADER ===== */
.part {
  margin-bottom: 72px;
  opacity: 1;
  transform: translateY(0);
  transition: opacity 0.7s ease, transform 0.7s ease;
}
.part.revealed {
  opacity: 1;
  transform: translateY(0);
}

.part-header {
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 32px;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--border);
}
.part-number {
  font-family: var(--font-heading);
  font-size: 48px;
  font-weight: 900;
  background: var(--accent-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1;
  min-width: 60px;
  opacity: 0.8;
}
.part-title {
  font-family: var(--font-heading);
  font-size: clamp(20px, 3vw, 28px);
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.3;
}
.part-label {
  font-size: 12px;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 1px;
  font-weight: 600;
}

/* ===== STEP ===== */
.step {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 28px 32px;
  margin-bottom: 20px;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}
.step:hover {
  border-color: var(--border-glow);
  box-shadow: 0 0 30px rgba(255, 107, 74, 0.05);
}
.step h4 {
  font-family: var(--font-heading);
  font-size: 16px;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 14px;
}
.step p, .step li {
  color: var(--text-secondary);
  font-size: 15px;
  line-height: 1.8;
}
.step ol, .step ul {
  padding-left: 24px;
  margin: 12px 0;
}
.step li { margin-bottom: 8px; }
.step strong { color: var(--text-primary); font-weight: 600; }
.step a {
  color: var(--accent);
  text-decoration: none;
  border-bottom: 1px dashed var(--accent);
  transition: border-bottom-style 0.2s;
}
.step a:hover { border-bottom-style: solid; }

/* ===== CODE BLOCKS ===== */
.code-block {
  position: relative;
  background: var(--bg-code);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  margin: 16px 0;
  overflow: hidden;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}
.code-block:hover {
  border-color: rgba(255, 107, 74, 0.2);
  box-shadow: 0 0 20px rgba(255, 107, 74, 0.05);
}
.code-block pre {
  font-family: var(--font-mono);
  font-size: 14px;
  line-height: 1.7;
  padding: 20px 24px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  white-space: pre-wrap;
  word-break: break-all;
  color: #ccd0e0;
}
.code-block .copy-btn {
  position: absolute;
  top: 10px;
  right: 10px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: var(--text-muted);
  border-radius: var(--radius-xs);
  padding: 6px 12px;
  font-size: 12px;
  font-family: var(--font-sans);
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  gap: 5px;
}
.code-block .copy-btn:hover {
  background: rgba(255, 107, 74, 0.12);
  border-color: rgba(255, 107, 74, 0.3);
  color: var(--accent);
}
.code-block .copy-btn.copied {
  background: rgba(74, 222, 128, 0.12);
  border-color: rgba(74, 222, 128, 0.3);
  color: var(--success);
}
.code-inline {
  font-family: var(--font-mono);
  font-size: 13px;
  background: rgba(255, 107, 74, 0.08);
  border: 1px solid rgba(255, 107, 74, 0.15);
  padding: 2px 8px;
  border-radius: 5px;
  color: var(--accent-soft);
  word-break: break-all;
}

/* ===== SCREENSHOT PLACEHOLDERS ===== */
.screenshot-placeholder {
  margin: 20px 0;
  border-radius: var(--radius);
  overflow: hidden;
  border: 1px solid var(--border);
  background: var(--bg-card);
  transition: border-color 0.3s ease;
}
.screenshot-placeholder:hover {
  border-color: var(--border-glow);
}
.screenshot-placeholder-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 180px;
  padding: 40px 24px;
  background:
    repeating-linear-gradient(
      45deg,
      transparent,
      transparent 20px,
      rgba(255, 107, 74, 0.02) 20px,
      rgba(255, 107, 74, 0.02) 40px
    );
}
.screenshot-placeholder-icon {
  font-size: 36px;
  margin-bottom: 12px;
  opacity: 0.6;
}
.screenshot-placeholder-text {
  font-size: 14px;
  color: var(--text-muted);
  text-align: center;
  line-height: 1.5;
}
.screenshot-placeholder-caption {
  padding: 12px 16px;
  font-size: 13px;
  color: var(--text-muted);
  background: rgba(255, 107, 74, 0.03);
  border-top: 1px solid var(--border);
  text-align: center;
}
.screenshot-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin: 20px 0;
}
@media (max-width: 640px) {
  .screenshot-row { grid-template-columns: 1fr; }
}
.screenshot {
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--border);
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s;
}
.screenshot:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.3);
}
.screenshot img {
  width: 100%;
  display: block;
}
.screenshot-caption {
  padding: 10px 14px;
  font-size: 13px;
  color: var(--text-muted);
  background: var(--card-bg);
  text-align: center;
}
.lightbox {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0,0,0,0.9);
  align-items: center;
  justify-content: center;
  cursor: zoom-out;
}
.lightbox.active { display: flex; }
.lightbox img {
  max-width: 95vw;
  max-height: 95vh;
  border-radius: 12px;
  transform: scale(0.95);
  transition: transform 0.3s;
}
.lightbox.active img { transform: scale(1); }

/* ===== CALLOUTS ===== */
.callout {
  padding: 20px 24px;
  border-radius: var(--radius-sm);
  margin: 20px 0;
  font-size: 14px;
  line-height: 1.7;
  display: flex;
  gap: 14px;
}
.callout-icon {
  font-size: 20px;
  flex-shrink: 0;
  line-height: 1.5;
}
.callout-warning {
  background: rgba(251, 191, 36, 0.06);
  border: 1px solid rgba(251, 191, 36, 0.15);
  color: #fcd668;
}
.callout-tip {
  background: rgba(74, 222, 128, 0.06);
  border: 1px solid rgba(74, 222, 128, 0.15);
  color: #86efac;
}
.callout-info {
  background: rgba(96, 165, 250, 0.06);
  border: 1px solid rgba(96, 165, 250, 0.15);
  color: #93c5fd;
}
.callout a { color: inherit; text-decoration: underline; text-underline-offset: 2px; }

/* ===== CHEAT SHEET ===== */
.cheat-sheet {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  margin: 32px 0;
}
.cheat-sheet-header {
  padding: 20px 28px;
  background: rgba(255, 107, 74, 0.05);
  border-bottom: 1px solid var(--border);
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 16px;
  color: var(--accent);
}
.cheat-sheet-row {
  display: flex;
  align-items: baseline;
  gap: 16px;
  padding: 14px 28px;
  border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  font-size: 14px;
  transition: background 0.2s;
}
.cheat-sheet-row:last-child { border-bottom: none; }
.cheat-sheet-row:hover { background: rgba(255, 107, 74, 0.03); }
.cheat-sheet-cmd {
  font-family: var(--font-mono);
  color: var(--accent-soft);
  white-space: normal;
  word-break: break-all;
  min-width: 200px;
  font-size: 13px;
}
.cheat-sheet-desc { color: var(--text-muted); font-size: 13px; }

/* ===== MODEL CARDS ===== */
.model-grid {
  display: flex;
  flex-direction: column;
  gap: 16px;
  margin: 20px 0;
}
.model-card {
  background: var(--bg-code);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 24px;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}
.model-card-details {
  margin-top: 12px;
  font-size: 14px;
  color: var(--text-secondary);
  line-height: 1.7;
}
.model-card-details ul {
  margin: 8px 0 0 18px;
  padding: 0;
}
.model-card-details li {
  margin-bottom: 4px;
}
.model-card:hover {
  border-color: var(--border-glow);
  box-shadow: 0 0 20px rgba(255, 107, 74, 0.05);
}
.model-card-name {
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 15px;
  color: var(--text-primary);
  margin-bottom: 6px;
}
.model-card-desc {
  font-size: 13px;
  color: var(--text-muted);
  line-height: 1.5;
}
.model-card-badge {
  display: inline-block;
  margin-top: 10px;
  padding: 3px 10px;
  border-radius: 100px;
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.3px;
}
.badge-free {
  background: rgba(74, 222, 128, 0.1);
  color: var(--success);
  border: 1px solid rgba(74, 222, 128, 0.2);
}
.badge-best {
  background: rgba(255, 107, 74, 0.1);
  color: var(--accent);
  border: 1px solid rgba(255, 107, 74, 0.2);
}
.badge-power {
  background: rgba(168, 85, 247, 0.1);
  color: #c084fc;
  border: 1px solid rgba(168, 85, 247, 0.2);
}
.badge-fast {
  background: rgba(96, 165, 250, 0.1);
  color: #93c5fd;
  border: 1px solid rgba(96, 165, 250, 0.2);
}
.badge-cheap {
  background: rgba(251, 191, 36, 0.1);
  color: #fcd668;
  border: 1px solid rgba(251, 191, 36, 0.2);
}

/* ===== SOURCE LINK ===== */
.source-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: 12px;
  padding: 6px 14px;
  background: rgba(255, 107, 74, 0.05);
  border: 1px solid rgba(255, 107, 74, 0.12);
  border-radius: 100px;
  font-size: 12px;
  color: var(--accent);
  text-decoration: none;
  transition: background 0.2s, border-color 0.2s;
}
.source-link:hover {
  background: rgba(255, 107, 74, 0.1);
  border-color: rgba(255, 107, 74, 0.25);
}
.source-link svg { width: 14px; height: 14px; flex-shrink: 0; }

/* ===== DONE SECTION ===== */
.done-section {
  text-align: center;
  padding: 60px 24px;
  margin: 40px 0;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  position: relative;
  overflow: hidden;
}
.done-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 60% 60% at 50% 40%, rgba(255, 107, 74, 0.06) 0%, transparent 70%);
  pointer-events: none;
}
.done-emoji {
  font-size: 64px;
  margin-bottom: 20px;
  position: relative;
  z-index: 1;
}
.done-title {
  font-family: var(--font-heading);
  font-size: clamp(24px, 4vw, 36px);
  font-weight: 800;
  background: var(--accent-gradient);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 16px;
  position: relative;
  z-index: 1;
}
.done-text {
  font-size: 17px;
  color: var(--text-secondary);
  max-width: 500px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
  line-height: 1.7;
}

.part:last-of-type {
  margin-bottom: 0;
}

/* ===== FOOTER ===== */
.footer {
  text-align: center;
  padding: 48px 24px;
  border-top: 1px solid var(--border);
  color: var(--text-muted);
  font-size: 13px;
}
.footer-links {
  display: flex;
  justify-content: center;
  gap: 32px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}
.footer-links a {
  color: var(--text-secondary);
  text-decoration: none;
  transition: color 0.2s;
  font-size: 14px;
}
.footer-links a:hover { color: var(--accent); }
.footer-divider {
  width: 40px;
  height: 2px;
  background: var(--accent);
  margin: 20px auto;
  border-radius: 1px;
  opacity: 0.4;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 768px) {
  .part-header { flex-direction: column; align-items: flex-start; gap: 8px; }
  .part-number { font-size: 36px; }
  .step { padding: 20px; }
  .cheat-sheet-row { flex-direction: column; gap: 4px; }
  .cheat-sheet-cmd { min-width: auto; }
  .hero-ascii { font-size: 6px; }
  .code-block pre { font-size: 12px; padding: 16px; }

}

/* ===== REDUCED MOTION ===== */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
  .part { opacity: 1; transform: none; }
  html { scroll-behavior: auto; }
}
</style>
</head>
<body>

<!-- Progress Bar -->
<div class="progress-bar" id="progressBar"></div>

<!-- ===== HERO ===== -->
<section class="hero" id="hero">
  <div class="hero-grid"></div>
